# ============================================================
#  Revolut MCP — Sandbox Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ----- Revolut Developer Portal Credentials -----------------
# Obtain from: https://developer.revolut.com/portal
REVOLUT_CLIENT_ID=your_client_id_here

# ----- mTLS Certificate Paths --------------------------------
# Generated via Developer Portal → Sandbox → Authentication tab.
# Run: openssl req -newkey rsa:2048 -nodes -keyout private.key -x509 -days 365 -out transport.pem
# Then upload the CSR/cert to the portal.
REVOLUT_CERT_PATH=./certs/transport.pem
REVOLUT_KEY_PATH=./certs/private.key

# ----- JWT Signing Key (for Authorization Request JWT) -------
# If you have a separate signing key, set it here.
# If not provided, the transport key (REVOLUT_KEY_PATH) will be used.
# REVOLUT_SIGNING_KEY_PATH=./certs/signing.key

# ----- OAuth2 Redirect URI -----------------------------------
# Must match what is configured in the Developer Portal.
# For local testing, any URL works since you'll copy the code manually.
REVOLUT_REDIRECT_URI=https://localhost:3000/callback

# ----- Token Storage -----------------------------------------
# Path where OAuth tokens are persisted between server restarts.
TOKEN_STORE_PATH=./.tokens.json

# ----- API Environment (do not change for sandbox) -----------
REVOLUT_ENVIRONMENT=sandbox
