# ============================================================
#  Revolut MCP — Business API Sandbox Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env, your private key, or .tokens.json.
# ============================================================

# ----- Client ID --------------------------------------------
# From the Revolut Business portal: Settings → APIs → Business API,
# shown on the API certificate you created.
REVOLUT_CLIENT_ID=your_client_id_here

# ----- Private key (signs the client-assertion JWT) ----------
# The public X.509 certificate is uploaded to the portal; the matching
# private key stays here and signs the JWT used at the token endpoint.
# Provide EITHER a path to the PEM file...
REVOLUT_PRIVATE_KEY_PATH=./certs/privatekey.pem
# ...OR the PEM contents inline (takes precedence; handy in containers):
# REVOLUT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ----- OAuth redirect URI ------------------------------------
# Must match the URI registered with the certificate. It must be a public
# HTTPS URL (localhost is rejected by Revolut's consent page). You only ever
# copy the `code` query parameter from it, so https://example.com/ works.
REVOLUT_REDIRECT_URI=https://example.com/

# ----- JWT issuer (iss) --------------------------------------
# Must equal the host of the redirect URI. Defaults to that host if omitted.
# REVOLUT_JWT_ISS=example.com

# ----- Token storage -----------------------------------------
# Where OAuth access/refresh tokens are persisted between restarts.
TOKEN_STORE_PATH=./.tokens.json

# ----- Environment -------------------------------------------
# sandbox (default) → sandbox-b2b.revolut.com
# production        → b2b.revolut.com  (requires a production certificate)
REVOLUT_ENVIRONMENT=sandbox
