# Revolut Open Banking API Configuration
# Environment: 'sandbox' or 'production'
REVOLUT_ENVIRONMENT=sandbox

# OAuth 2.0 Client ID (from TPP registration / Dynamic Client Registration)
REVOLUT_CLIENT_ID=your_client_id_here

# Path to the signing private key (PEM) - used for client_assertion JWT and JWS signatures
REVOLUT_SIGNING_KEY=./certs/signing.key

# Key ID (kid) for JWS header - matches the key registered with Revolut
REVOLUT_SIGNING_KEY_ID=your_signing_key_id_here

# Path to the transport certificate (PEM) - used for mTLS
REVOLUT_TRANSPORT_CERT=./certs/transport.pem

# Path to the transport private key (PEM) - used for mTLS
REVOLUT_TRANSPORT_KEY=./certs/transport.key

# OAuth redirect URI (registered with Revolut)
REVOLUT_REDIRECT_URI=https://example.com/callback
